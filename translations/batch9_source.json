      "key": "challenge_description_cashvalue",
      "source": "This challenge measures how much money a park has in the bank! This is calculated at the End of Day Report.",
      "context": "",
      "max_length": null
    },
    {
      "key": "challenge_description_dailycoasterriders",
      "source": "This challenge measures a park's daily number of coaster rides enjoyed by guests. This is calculated at the End of Day Report.",
      "context": "",
      "max_length": null
    },
    {
      "key": "challenge_description_dailyflumeriders",
      "source": "This challenge measures a park's daily number of flume rides enjoyed by guests. This is calculated at the End of Day Report.",
      "context": "",
      "max_length": null
    },
    {
      "key": "challenge_description_dailyincome",
      "source": "This challenge is scored on the total daily income a park generates! This is calculated at the End of Day Report.",
