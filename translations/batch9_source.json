      "max_length": null
    },
    {
      "key": "challenge_description_dailyincomeattractions",
      "source": "This challenge measures a park's daily income from attraction tickets, including coasters, tracked rides and flat rides. This is calculated at the End of Day Report.",
      "context": "",
      "max_length": null
    },
    {
      "key": "challenge_description_dailyincomeshops",
      "source": "This challenge measures a park's daily income from shops, including food and drink, souvenirs, and from guest services. This is calculated at the End of Day Report.",
